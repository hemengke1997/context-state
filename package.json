{
  "name": "context-state",
  "version": "1.1.6",
  "description": "React state management library",
  "author": "hemengke1997 <23536175@qq.com>",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hemengke1997/context-state.git"
  },
  "homepage": "https://github.com/hemengke1997/context-state",
  "bugs": {
    "url": "https://github.com/hemengke1997/context-state/issues"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "hook",
    "state management"
  ],
  "license": "MIT",
  "scripts": {
    "start": "vite dev",
    "build": "vite build",
    "build-watch": "vite build --watch",
    "serve": "vite preview",
    "lint-staged:js": "eslint --ext .js,.jsx,.ts,.tsx",
    "precommit": "lint-staged",
    "prettier": "prettier -c --write \"src/**/*\"",
    "test": "jest",
    "prepublish": "yarn build",
    "upgrade:deps": "yarn upgrade-interactive --latest"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": "npm run lint-staged:js",
    "**/*.{js,jsx,tsx,ts,less,md,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "react": "^17.0.0",
    "react-dom": "^17.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.16.5",
    "@babel/preset-env": "^7.16.5",
    "@babel/preset-react": "^7.16.5",
    "@babel/preset-typescript": "^7.16.5",
    "@rollup/plugin-typescript": "^8.3.0",
    "@testing-library/jest-dom": "^5.16.1",
    "@testing-library/react": "^12.0.0",
    "@testing-library/user-event": "^13.1.9",
    "@types/node": "^17.0.5",
    "@types/react": "^17.0.38",
    "@types/react-dom": "^17.0.0",
    "@typescript-eslint/eslint-plugin": "^5.8.1",
    "@typescript-eslint/parser": "^5.8.1",
    "@vitejs/plugin-react": "^1.1.3",
    "babel-jest": "^27.4.5",
    "eslint": "^8.5.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-define-config": "^1.2.1",
    "eslint-plugin-prettier": "^4.0.0",
    "gh-pages": "^3.2.3",
    "husky": "^7.0.0",
    "jest": "^27.4.5",
    "lint-staged": "^12.1.4",
    "prettier": "^2.3.2",
    "tslib": "^2.3.1",
    "typescript": "^4.5.4",
    "vite": "^2.7.9"
  }
}
